image: php:8.2

pipelines:
  default:
    - step:
        name: "PHP 8.1"
        image: php:8.1
        script:
          - apt-get update && apt-get install -y git unzip
          - curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
          - composer install --prefer-dist --no-progress
          - composer test
          - composer analyse
          - composer lint
    - step:
        name: "PHP 8.2"
        image: php:8.2
        script:
          - apt-get update && apt-get install -y git unzip
          - curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
          - composer install --prefer-dist --no-progress
          - composer test
          - composer analyse
          - composer lint
    - step:
        name: "PHP 8.3"
        image: php:8.3
        script:
          - apt-get update && apt-get install -y git unzip
          - curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer
          - composer install --prefer-dist --no-progress
          - composer test
          - composer analyse
          - composer lint
