<?php
/**
 * PHPUnit bootstrap for {{plugin_name}} unit tests.
 *
 * Loads the Composer autoloader and WordPress function stubs so unit tests
 * can run without a live WordPress installation.
 *
 * @package {{plugin_namespace_test}}
 * @since   0.1.0
 */

defined( 'ABSPATH' ) || define( 'ABSPATH', dirname( __DIR__ ) . '/' );
defined( '{{plugin_const_prefix}}_VERSION' ) || define( '{{plugin_const_prefix}}_VERSION', '0.1.0' );
defined( '{{plugin_const_prefix}}_PATH' ) || define( '{{plugin_const_prefix}}_PATH', dirname( __DIR__ ) . '/' );
defined( '{{plugin_const_prefix}}_URL' ) || define( '{{plugin_const_prefix}}_URL', 'https://example.com/wp-content/plugins/{{plugin_slug}}/' );
defined( '{{plugin_const_prefix}}_PLUGIN_FILE' ) || define( '{{plugin_const_prefix}}_PLUGIN_FILE', dirname( __DIR__ ) . '/{{plugin_slug}}.php' );

$autoloader = dirname( __DIR__ ) . '/vendor/autoload.php';

if ( ! is_readable( $autoloader ) ) {
	echo "ERROR: vendor/autoload.php not found. Run 'composer install'.\n"; // phpcs:ignore WordPress.Security.EscapeOutput
	exit( 1 );
}

require $autoloader;

// WordPress function stubs for unit tests.
require_once __DIR__ . '/stubs/functions.php';
