{{=<% %>=}}
name: Tests

on:
  push:
    branches: [ '**' ]
    tags-ignore: [ '**' ]
  pull_request:
    types: [ opened, synchronize, reopened ]

jobs:
  # ── Plugin header consistency ─────────────────────────────────────────────────
  headers:
    name: Plugin header consistency
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - name: Check required header fields exist
        run: |
          check_field() {
            local label=$1 pattern=$2 file=$3
            if ! grep -qE "$pattern" "$file"; then
              echo "✗  '$label' not found in $file"
              exit 1
            fi
            echo "✔  $label: $(grep -oE "$pattern" "$file" | head -1)"
          }

          check_field "Plugin Name"       "Plugin Name:"                      "<%plugin_slug%>.php"
          check_field "Version"           "Version:[[:space:]]+[0-9]+\.[0-9]" "<%plugin_slug%>.php"
          check_field "Requires at least" "Requires at least:[[:space:]]+[0-9]" "<%plugin_slug%>.php"
          check_field "Requires PHP"      "Requires PHP:[[:space:]]+[0-9]"     "<%plugin_slug%>.php"
          check_field "Tested up to"      "Tested up to:[[:space:]]+[0-9]"     "<%plugin_slug%>.php"
          check_field "License"           "License:[[:space:]]+GPL"            "<%plugin_slug%>.php"
          check_field "readme Stable tag" "Stable tag:[[:space:]]+[0-9]+\.[0-9]" "readme.txt"

      - name: Version == Stable tag
        run: |
          MAIN=$(grep -oE "Version:[[:space:]]+[0-9][^[:space:]]*" <%plugin_slug%>.php | head -1 | grep -oE "[0-9][^[:space:]]*")
          README=$(grep -oE "Stable tag:[[:space:]]+[0-9][^[:space:]]*" readme.txt | grep -oE "[0-9][^[:space:]]*")
          [ "$MAIN" = "$README" ] && echo "✔  Version: $MAIN" || { echo "✗  Mismatch: <%plugin_slug%>.php=$MAIN readme.txt=$README"; exit 1; }

      - name: Requires at least consistent
        run: |
          MAIN=$(grep -oE "Requires at least:[[:space:]]+[0-9][^[:space:]]*" <%plugin_slug%>.php | grep -oE "[0-9][^[:space:]]*")
          README=$(grep -oE "Requires at least:[[:space:]]+[0-9][^[:space:]]*" readme.txt | grep -oE "[0-9][^[:space:]]*")
          [ "$MAIN" = "$README" ] && echo "✔  Requires at least: $MAIN" || { echo "✗  Mismatch: $MAIN vs $README"; exit 1; }

      - name: Requires PHP consistent
        run: |
          MAIN=$(grep -oE "Requires PHP:[[:space:]]+[0-9][^[:space:]]*" <%plugin_slug%>.php | grep -oE "[0-9][^[:space:]]*")
          README=$(grep -oE "Requires PHP:[[:space:]]+[0-9][^[:space:]]*" readme.txt | grep -oE "[0-9][^[:space:]]*")
          [ "$MAIN" = "$README" ] && echo "✔  Requires PHP: $MAIN" || { echo "✗  Mismatch: $MAIN vs $README"; exit 1; }

  # ── README.md in sync with readme.txt ─────────────────────────────────────────
  readme:
    name: README.md in sync
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Install dependencies
        run: npm ci

      - name: Generate README.md
        run: npm run readme

      - name: Check README.md is up to date
        run: |
          if ! git diff --exit-code README.md; then
            echo ""
            echo "✗  README.md is out of sync with readme.txt."
            echo "   Run 'npm run readme' locally and commit the result."
            exit 1
          fi
          echo "✔  README.md is up to date."

  # ── PHPCS + WPCS + PHPCompatibility ──────────────────────────────────────────
  phpcs:
    name: PHPCS / WPCS / PHP Compat (8.1+)
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - uses: shivammathur/setup-php@v2
        with:
          php-version: '8.2'
          tools: composer:v2

      - id: composer-cache
        run: echo "dir=$(composer config cache-files-dir)" >> $GITHUB_OUTPUT

      - name: Cache Composer
        uses: actions/cache@v4
        with:
          path: ${{ steps.composer-cache.outputs.dir }}
          key: composer-phpcs-${{ hashFiles('composer.json') }}
          restore-keys: composer-phpcs-

      - name: Install dependencies
        run: composer install --no-interaction --prefer-dist --no-scripts

      - name: PHPCS
        run: composer lint

  # ── PHPUnit ──────────────────────────────────────────────────────────────────
  phpunit:
    name: PHPUnit (PHP ${{ matrix.php }})
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        php: [ '8.1', '8.2', '8.3', '8.4' ]

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - uses: shivammathur/setup-php@v2
        with:
          php-version: ${{ matrix.php }}
          coverage: xdebug
          tools: composer:v2

      - id: composer-cache
        run: echo "dir=$(composer config cache-files-dir)" >> $GITHUB_OUTPUT

      - name: Cache Composer
        uses: actions/cache@v4
        with:
          path: ${{ steps.composer-cache.outputs.dir }}
          key: composer-php${{ matrix.php }}-${{ hashFiles('composer.lock') }}
          restore-keys: composer-php${{ matrix.php }}-

      - name: Install dependencies
        run: composer install --no-interaction --prefer-dist --no-scripts

      - name: PHPUnit
        run: composer test

      - name: Upload coverage
        if: matrix.php == '8.2'
        uses: actions/upload-artifact@v4
        with:
          name: phpunit-coverage
          path: tests/coverage/

  # ── PHPStan ──────────────────────────────────────────────────────────────────
  phpstan:
    name: PHPStan
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - uses: shivammathur/setup-php@v2
        with:
          php-version: '8.2'
          tools: composer:v2

      - name: Install dependencies
        run: composer install --no-interaction --prefer-dist --no-scripts

      - name: PHPStan
        run: composer analyse

  # ── Playwright E2E ───────────────────────────────────────────────────────────
  playwright:
    name: Playwright E2E
    runs-on: ubuntu-latest
    if: false  # Enable once a CI WordPress environment is configured.

    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - run: npm ci
      - run: npx playwright install chromium --with-deps

      - name: Run E2E tests
        env:
          <%plugin_const_prefix%>_BASE_URL: ${{ secrets.<%plugin_const_prefix%>_BASE_URL }}
          <%plugin_const_prefix%>_ADMIN_USER: ${{ secrets.<%plugin_const_prefix%>_ADMIN_USER }}
          <%plugin_const_prefix%>_ADMIN_PASS: ${{ secrets.<%plugin_const_prefix%>_ADMIN_PASS }}
        run: npm run test:e2e

      - name: Upload Playwright report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: playwright-report
          path: playwright-report/
          retention-days: 7
