includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6
    paths:
        - src
        - {{plugin_slug}}.php
    excludePaths:
        - vendor/
        - tests/
        - node_modules/
    bootstrapFiles:
        - phpstan-bootstrap.php
    parallel:
        maximumNumberOfProcesses: 1
    treatPhpDocTypesAsCertain: false
    checkMissingIterableValueType: false
