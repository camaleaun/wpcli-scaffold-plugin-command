{{=<% %>=}}
name: Try in Playground

on:
  push:
    branches: ['**']
    tags-ignore: ['**']
  pull_request:
    types: [opened, synchronize, reopened]

permissions:
  contents: read
  pull-requests: write

jobs:
  build-zip:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          submodules: recursive

      - name: Build plugin zip
        run: |
          mkdir -p /tmp/build
          git archive HEAD --prefix=<%plugin_slug%>/ | tar xf - -C /tmp/build/
          git -C lib/selfdirectory archive HEAD \
            --prefix=<%plugin_slug%>/lib/selfdirectory/ \
            -- class-selfdirectory.php \
            | tar xf - -C /tmp/build/
          cd /tmp/build && zip -r <%plugin_slug%>.zip <%plugin_slug%>

      - name: Upload plugin zip
        uses: actions/upload-artifact@v4
        with:
          name: plugin-zip
          path: /tmp/build/<%plugin_slug%>.zip
          retention-days: 7

  comment-playground:
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'
    needs: build-zip
    steps:
      - name: Post Playground link
        uses: actions/github-script@v7
        with:
          script: |
            const owner = context.repo.owner;
            const repo = context.repo.repo;
            const sha = context.payload.pull_request.head.sha;
            const blueprintUrl = encodeURIComponent(
              `https://raw.githubusercontent.com/${owner}/${repo}/${sha}/blueprint-dev.json`
            );
            const url = `https://playground.wordpress.net/?gh-ensure-auth=yes&blueprint-url=${blueprintUrl}`;

            const body = [
              '### Try in Playground',
              '',
              `[![Try in Playground](https://img.shields.io/badge/Try%20in-WordPress%20Playground-3858e9?logo=wordpress&logoColor=white)](${url})`,
              '',
              `[Open this PR in WordPress Playground](${url})`,
              '',
              '> Sign in with GitHub when prompted so Playground can access the build artifact.',
            ].join('\n');

            const { data: comments } = await github.rest.issues.listComments({
              owner, repo, issue_number: context.issue.number,
            });
            const existing = comments.find(
              c => c.user.type === 'Bot' && c.body.includes('Try in Playground')
            );
            if (existing) {
              await github.rest.issues.updateComment({
                owner, repo, comment_id: existing.id, body,
              });
            } else {
              await github.rest.issues.createComment({
                owner, repo, issue_number: context.issue.number, body,
              });
            }
